local function C_3d()
local script = G2L["3d"];
	local Players = game:GetService("Players")
	local localPlayer = Players.LocalPlayer
	
	local SaveToggle = script.Parent.SaveToggle
	local MainFrame = script.Parent.Parent.Parent.Parent
	
	local FILE_NAME = "universalscript_save.txt"
	local saveEnabled = false
	local isApplyingLoad = false
	
	local function readFile()
		local success, result = pcall(function()
			return readfile(FILE_NAME)
		end)
		if success and result and result ~= "" then return result end
		return nil
	end
	
	local function writeFile(content)
		pcall(function()
			writefile(FILE_NAME, content)
		end)
	end
	
	local function loadSave()
		local data = readFile()
		if not data then return nil end
		local decoded = {}
		for line in data:gmatch("[^\n]+") do
			local key, value = line:match("(.-)=(.+)")
			if key and value then
				decoded[key] = value
			end
		end
		if decoded["saveEnabled"] ~= "true" then return nil end
		return next(decoded) and decoded or nil
	end
	
	local function isToggleButton(child)
		if not child:IsA("TextButton") then return false end
		if not child.Name:match("Toggle$") then return false end
		if child.Text ~= "ON" and child.Text ~= "OFF" then return false end
		return true
	end
	
	local function saveData()
		if not saveEnabled then return end
		local lines = {}
	
		table.insert(lines, "saveEnabled=true")
	
		local pos = MainFrame.Position
		table.insert(lines, "posX=" .. pos.X.Offset)
		table.insert(lines, "posY=" .. pos.Y.Offset)
	
		local isMinimized = MainFrame.Size.Y.Offset == 25
		table.insert(lines, "minimized=" .. tostring(isMinimized))
	
		local ContentFrame = MainFrame.ContentFrame
		for _, page in pairs(ContentFrame:GetChildren()) do
			if page:IsA("Frame") then
				for _, row in pairs(page:GetChildren()) do
					if row:IsA("Frame") then
						for _, child in pairs(row:GetChildren()) do
							if isToggleButton(child) then
								table.insert(lines, row.Name .. "_" .. child.Name .. "=" .. child.Text)
							end
							if child:IsA("TextBox") then
								local text = child.Text ~= "" and child.Text or "empty"
								table.insert(lines, row.Name .. "_" .. child.Name .. "_text=" .. text)
							end
						end
					end
				end
			end
		end
	
		writeFile(table.concat(lines, "\n"))
	end
	
	local function showLoadedMessage()
		-- remove any existing loaded message
		local existing = MainFrame:FindFirstChild("ScriptsLoadedLabel")
		if existing then existing:Destroy() end
	
		local label = Instance.new("TextLabel")
		label.Name = "ScriptsLoadedLabel"
		label.Size = UDim2.new(0, 200, 0, 20)
		label.Position = UDim2.new(0, 0, 0, 245) -- just above bottombar
		label.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		label.BorderSizePixel = 1
		label.BorderColor3 = Color3.fromRGB(255, 255, 255)
		label.Text = "SCRIPTS LOADED"
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextScaled = true
		label.Font = Enum.Font.SourceSans
		label.ZIndex = 10
		label.BackgroundTransparency = 0
		label.TextTransparency = 0
		label.Parent = MainFrame
	
		-- fade out
		task.spawn(function()
			task.wait(1.5)
			local steps = 20
			for i = 1, steps do
				if not label or not label.Parent then break end
				local t = i / steps
				label.TextTransparency = t
				label.BackgroundTransparency = t
				label.BorderSizePixel = 0
				task.wait(0.05)
			end
			if label and label.Parent then
				label:Destroy()
			end
		end)
	end
	
	local function applyLoad(data)
		if not data or isApplyingLoad then return end
		isApplyingLoad = true
		
		-- Set attribute to prevent drag script from interfering
		MainFrame:SetAttribute("IsLoading", true)
		
		-- Disable built-in dragging during load to prevent conflicts
		local wasDraggable = MainFrame.Draggable
		MainFrame.Draggable = false
	
		local x = tonumber(data["posX"])
		local y = tonumber(data["posY"])
		if x and y then
			MainFrame.Position = UDim2.new(0, x, 0, y)
		end
	
		if data["minimized"] == "true" then
			MainFrame.Size = UDim2.new(0, 200, 0, 25)
			MainFrame.ContentFrame.Visible = false
			MainFrame.BottomBar.Visible = false
			MainFrame.TopBar.MinimizeBtn.Text = "+"
		else
			-- Make sure ContentFrame is visible if not minimized
			MainFrame.ContentFrame.Visible = true
			MainFrame.BottomBar.Visible = true
		end
	
		task.wait(0.5)
	
		local ContentFrame = MainFrame.ContentFrame
		for _, page in pairs(ContentFrame:GetChildren()) do
			if page:IsA("Frame") then
				for _, row in pairs(page:GetChildren()) do
					if row:IsA("Frame") then
						for _, child in pairs(row:GetChildren()) do
							if isToggleButton(child) then
								local savedValue = data[row.Name .. "_" .. child.Name]
								if savedValue == "ON" and child.Text == "OFF" then
									pcall(function()
										firesignal(child.MouseButton1Click)
									end)
									task.wait(0.15)
								end
							end
							if child:IsA("TextBox") then
								local savedText = data[row.Name .. "_" .. child.Name .. "_text"]
								if savedText and savedText ~= "empty" then
									child.Text = savedText
								end
							end
						end
					end
				end
			end
		end
	
		task.wait(0.5)
		isApplyingLoad = false
		
		-- Clear attribute to allow dragging again
		MainFrame:SetAttribute("IsLoading", false)
		
		-- Re-enable dragging after load is complete
		MainFrame.Draggable = wasDraggable
	
		-- show loaded message after everything is done
		showLoadedMessage()
	end
	
	local function showPopup(data)
		local isMinimized = MainFrame.Size.Y.Offset == 25
	
		local PopupFrame = Instance.new("Frame")
		PopupFrame.Name = "SavePopup"
