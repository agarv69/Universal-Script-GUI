local function TDBVD_fake_script() -- ExploitGui.PageListButtonSetup 
	local script = Instance.new('LocalScript', ExploitGui)

	task.wait(1) -- Initial wait
	
	local Players = game:GetService("Players")
	local player = Players.LocalPlayer
	
	local function setupButton()
	    if player then
	        local playerGui = player:FindFirstChild("PlayerGui")
	        if playerGui then
	            local exploitGui = playerGui:FindFirstChild("EXPLOIT")
	            if exploitGui then
	                local mainFrame = exploitGui.MainFrame
	                local pageListBtn = mainFrame:FindFirstChild("PageListBtn")
	                
	                if pageListBtn then
	                    -- Position it right above the BottomBar with no gap
	                    pageListBtn.Position = UDim2.new(1, -95, 1, -50)
	                    
	                    -- Black background, white border 1 pixel (matching theme)
	                    pageListBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	                    pageListBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	                    pageListBtn.BorderColor3 = Color3.fromRGB(255, 255, 255)
	                    pageListBtn.BorderSizePixel = 1
	                    
	                    -- Make sure it's visible (only when not minimized)
	                    local isMinimized = mainFrame.Size.Y.Offset == 25
	                    pageListBtn.Visible = not isMinimized
	                    pageListBtn.Active = not isMinimized
	                    pageListBtn.BackgroundTransparency = 0
	                    pageListBtn.TextTransparency = 0
	                    pageListBtn.ZIndex = 1000
	                    
	                    print("✓ Page List Button set up successfully!")
	                    print("  Position:", pageListBtn.Position)
	                    print("  Visible:", pageListBtn.Visible)
	                    print("  Parent:", pageListBtn.Parent.Name)
	                else
	                    print("✗ Page List Button not found!")
	                end
	            end
	        end
	    end
	end
	
	-- Run immediately
	setupButton()
	
	-- Run again after 2 seconds to catch any late-loading
	task.wait(2)
	setupButton()
	
	-- Run again after 5 seconds to be sure
	task.wait(3)
	setupButton()
	
end
