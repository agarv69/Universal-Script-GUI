					end
				end
			end
		end)
	
		local isR6 = hum.RigType == Enum.HumanoidRigType.R6
		local torso = isR6 and chr:FindFirstChild("Torso") or chr:FindFirstChild("UpperTorso")
		if not torso then return end
	
