		if targetPlayer.Character then
			local espData = createESPGui(targetPlayer)
			if espData then
				ESPGuis[targetPlayer] = espData
			end
		end
	
		targetPlayer.CharacterAdded:Connect(function()
			task.wait(0.5)
			if ESPEnabled then
