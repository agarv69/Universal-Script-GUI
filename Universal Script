local function NJPHLOJ_fake_script() -- TopBar.DuplicateCheck 
	local script = Instance.new('LocalScript', TopBar)

	local CoreGui = game:GetService("CoreGui")
	local PlayerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
	
	local thisGui = script.Parent.Parent.Parent
	
	local function destroyExisting()
		local existing = CoreGui:FindFirstChild("ExploitGui")
		if existing and existing ~= thisGui then
			existing:Destroy()
		end
		local existing2 = PlayerGui:FindFirstChild("ExploitGui")
		if existing2 and existing2 ~= thisGui then
			existing2:Destroy()
		end
	end
	
	destroyExisting()
end
