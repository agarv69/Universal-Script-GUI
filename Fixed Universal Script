	local function togglePageList()
		local existingFrame = MainFrame:FindFirstChild("PageListFrame")
	
		if existingFrame or (pageListOpen and pageListFrame) then
			pageListOpen = false
			if existingFrame then existingFrame:Destroy() end
			if pageListFrame then
				pageListFrame:Destroy()
				pageListFrame = nil
			end
		else
			pageListOpen = true
	
			pageListFrame = Instance.new("Frame")
			pageListFrame.Name = "PageListFrame"
			pageListFrame.Size = UDim2.new(0, 90, 0, 100)
			pageListFrame.Position = UDim2.new(0, 201, 0, 0)
