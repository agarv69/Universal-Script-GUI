local function JFAB_fake_script() -- BangRow.BangScript 
	local script = Instance.new('LocalScript', BangRow)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local localPlayer = Players.LocalPlayer
	
	local BangToggle = script.Parent.BangToggle
	local BangUser = script.Parent.BangUser
	
	local bangEnabled = false
	local bangAnim = nil
	local bang = nil
	local bangDied = nil
	local bangLoop = nil
	
	local function getTorso(character)
		character = character or localPlayer.Character
		return character:FindFirstChild("Torso") 
			or character:FindFirstChild("UpperTorso") 
			or character:FindFirstChild("LowerTorso") 
			or character:FindFirstChild("HumanoidRootPart")
	end
	
	local function stopBang()
		if bangDied then bangDied:Disconnect() end
		if bang then bang:Stop() end
		if bangAnim then bangAnim:Destroy() end
		if bangLoop then bangLoop:Disconnect() end
		bangDied = nil
		bang = nil
		bangAnim = nil
		bangLoop = nil
	end
	
	local function findPlayer(input)
		input = input:lower()
		for _, player in pairs(Players:GetPlayers()) do
			if player ~= localPlayer then
				if player.Name:lower():find(input) or player.DisplayName:lower():find(input) then
					return player
				end
			end
		end
		return nil
	end
	
	local function startBang(targetPlayer)
		stopBang()
		wait()
	
		local character = localPlayer.Character
		if not character then return end
	
		local humanoid = character:FindFirstChildWhichIsA("Humanoid")
		if not humanoid then return end
	
		local isR15 = character:FindFirstChild("UpperTorso") ~= nil
		bangAnim = Instance.new("Animation")
		bangAnim.AnimationId = isR15 and "rbxassetid://5918726674" or "rbxassetid://148840371"
		bang = humanoid:LoadAnimation(bangAnim)
		bang:Play(0.1, 1, 1)
		bang:AdjustSpeed(3)
	
		bangDied = humanoid.Died:Connect(function()
			stopBang()
		end)
	
		if targetPlayer then
			local bangOffset = CFrame.new(0, 0, 1.1)
			bangLoop = RunService.Stepped:Connect(function()
				pcall(function()
					local myRoot = getTorso(localPlayer.Character)
					local otherRoot = getTorso(targetPlayer.Character)
					if myRoot and otherRoot then
						myRoot.CFrame = otherRoot.CFrame * bangOffset
					end
				end)
			end)
		end
	end
	
	BangToggle.MouseButton1Click:Connect(function()
		bangEnabled = not bangEnabled
		if bangEnabled then
			local input = BangUser.Text
			local target = nil
			if input and input ~= "" then
				target = findPlayer(input)
			end
	
			if target then
				BangToggle.Text = "ON"
				BangToggle.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
				startBang(target)
			else
				-- no player found, stay off
				bangEnabled = false
				BangToggle.Text = "OFF"
				BangToggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			end
		else
			BangToggle.Text = "OFF"
			BangToggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			stopBang()
		end
	end)
	
	script.Parent.AncestryChanged:Connect(function()
		if not script:IsDescendantOf(game) then
			stopBang()
		end
	end)
end
