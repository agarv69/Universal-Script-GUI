			if popupDismissed then return end
			popupDismissed = true
			PopupFrame:Destroy()
			-- Apply load immediately to prevent drag interference
			applyLoad(data)
		end)
	end
	
	task.spawn(function()
		while true do
			task.wait(2)
			if saveEnabled then
				saveData()
			end
