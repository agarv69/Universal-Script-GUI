local function C_44()
local script = G2L["44"];
	local Players = game:GetService("Players")
	
	local localPlayer = Players.LocalPlayer
	local GravityEnabled = false
	local GravityToggle = script.Parent.GravityToggle
	local GravityBox = script.Parent.GravityBox
	
	local DEFAULT_GRAVITY = 196.2
	
	GravityBox.Text = ""
	
	local function getGravity()
		local text = string.lower(GravityBox.Text)
		
		-- Check for "inf" or "infinity"
		if text == "inf" or text == "infinity" then
			return math.huge
		end
		
		-- Check for 0 (zero gravity)
		local num = tonumber(GravityBox.Text)
		if num == 0 then
			return 0
		end
		
		-- Return the number if valid and positive, otherwise default
		return num and num > 0 and num or DEFAULT_GRAVITY
	end
	
	local function applyGravity()
		local character = localPlayer.Character
		if not character then return end
		if GravityEnabled then
			workspace.Gravity = getGravity()
		else
			workspace.Gravity = DEFAULT_GRAVITY
		end
	end
	
	GravityToggle.MouseButton1Click:Connect(function()
		GravityEnabled = not GravityEnabled
		if GravityEnabled then
			GravityToggle.Text = "ON"
			GravityToggle.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
		else
			GravityToggle.Text = "OFF"
			GravityToggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
		end
		applyGravity()
	end)
	
	GravityBox:GetPropertyChangedSignal("Text"):Connect(function()
		if GravityEnabled then
			applyGravity()
		end
	end)
	
	GravityBox.FocusLost:Connect(function()
		-- Validate input - only allow numbers, decimal, minus, or "inf"/"infinity"
		local text = string.lower(GravityBox.Text)
		if text == "inf" or text == "infinity" or text == "" then
			return
		end
		
		-- Check if it's a valid number
		local num = tonumber(GravityBox.Text)
		if num == nil then
			-- Not a valid number, revert to empty
			GravityBox.Text = ""
		end
	end)
	
	localPlayer.CharacterAdded:Connect(function(character)
		character:WaitForChild("Humanoid")
		applyGravity()
	end)
	
	script.Parent.AncestryChanged:Connect(function()
		if not script:IsDescendantOf(game) then
			workspace.Gravity = DEFAULT_GRAVITY
		end
	end)
end;
