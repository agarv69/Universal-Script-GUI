		end
	
		local MessageLabel = Instance.new("TextLabel")
		MessageLabel.Size = UDim2.new(0, 200, 0, 35)
		MessageLabel.Position = UDim2.new(0, 0, 0, 0)
		MessageLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		MessageLabel.BorderSizePixel = 1
		MessageLabel.BorderColor3 = Color3.fromRGB(255, 255, 255)
		MessageLabel.Text = "SAVE SCRIPTS IS ON. WOULD YOU LIKE TO DISABLE IT (10.0)"
		MessageLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		MessageLabel.TextScaled = true
		MessageLabel.Font = Enum.Font.SourceSans
		MessageLabel.TextWrapped = true
		MessageLabel.ZIndex = 10
		MessageLabel.Parent = PopupFrame
	
		local YesBtn = Instance.new("TextButton")
		YesBtn.Size = UDim2.new(0, 100, 0, 30)
		YesBtn.Position = UDim2.new(0, 0, 0, 35)
		YesBtn.BackgroundColor3 = Color3.fromRGB(125, 0, 0)
		YesBtn.BorderSizePixel = 1
		YesBtn.BorderColor3 = Color3.fromRGB(255, 255, 255)
		YesBtn.Text = "YES"
		YesBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		YesBtn.TextScaled = true
		YesBtn.Font = Enum.Font.SourceSans
		YesBtn.ZIndex = 10
		YesBtn.Parent = PopupFrame
	
		local NoBtn = Instance.new("TextButton")
		NoBtn.Size = UDim2.new(0, 100, 0, 30)
		NoBtn.Position = UDim2.new(0, 100, 0, 35)
		NoBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
		NoBtn.BorderSizePixel = 1
		NoBtn.BorderColor3 = Color3.fromRGB(255, 255, 255)
		NoBtn.Text = "NO, AND LOAD BACK MY SCRIPTS"
		NoBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		NoBtn.TextScaled = true
		NoBtn.Font = Enum.Font.SourceSans
		NoBtn.ZIndex = 10
		NoBtn.Parent = PopupFrame
	
		local popupDismissed = false
	
		task.spawn(function()
			local timeLeft = 10.0
